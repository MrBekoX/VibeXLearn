# =============================================================================
# VibeXLearn Platform - Production Environment Configuration (Example)
# =============================================================================
# Bu dosyayı .env.production olarak kopyalayın ve değerleri doldurun
# cp .env.production.example .env.production
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER REGISTRY
# ═══════════════════════════════════════════════════════════════════════════════
DOCKER_REGISTRY=your-registry.com/vibexlearn
API_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════════════════
# POSTGRESQL
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_DB=vibexlearn
POSTGRES_USER=vibex_admin
# Şifre oluştur: openssl rand -base64 32
POSTGRES_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════════════════════
# Şifre oluştur: openssl rand -base64 32
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# ELASTICSEARCH
# ═══════════════════════════════════════════════════════════════════════════════
ELASTICSEARCH_USERNAME=elastic
# Şifre oluştur: openssl rand -base64 24
ELASTICSEARCH_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════
# Secret oluştur: openssl rand -base64 64 (minimum 32 karakter)
JWT_SECRET=
JWT_ISSUER=VibeXLearnPlatform
JWT_AUDIENCE=VibeXLearnPlatform.Clients
JWT_ACCESS_TOKEN_EXPIRATION=15
JWT_REFRESH_TOKEN_EXPIRATION=7

# ═══════════════════════════════════════════════════════════════════════════════
# IYZICO ÖDEME (Production)
# ═══════════════════════════════════════════════════════════════════════════════
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_CALLBACK_URL=https://api.vibexlearn.com/api/payments/callback
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# HARİCİ SERVİSLER
# ═══════════════════════════════════════════════════════════════════════════════
GITHUB_PAT=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
SERTIFIER_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════════════════════════
ENABLE_MONITORING=false
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# BACKUP
# ═══════════════════════════════════════════════════════════════════════════════
BACKUP_RETENTION_DAYS=7

# ═══════════════════════════════════════════════════════════════════════════════
# ALERTING (Slack/Discord Webhook)
# ═══════════════════════════════════════════════════════════════════════════════
ALERT_WEBHOOK=
